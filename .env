# Spotify API Credentials
# Maak een app aan op developer.spotify.com en stel de Redirect URI in op: http://localhost:8000/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8080/callback

# Gemini API Key (verkrijg via aistudio.google.com)
GEMINI_API_KEY=

# SMTP E-mail Notificaties (Optioneel, vul in voor e-mail updates)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_TO_EMAIL=
